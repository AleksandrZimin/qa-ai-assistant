# Секреты
.env

# Локальный кэш контекста (личный для каждого тестировщика)
.context-cache/*
!.context-cache/README.md

# Локальные настройки Claude Code
.claude/settings.local.json

# Локальный контекст продуктовой команды — адаптация стандартов под свой продукт/проект.
# В общий репозиторий уходит только структура папок и README.md с инструкциями.
local/**
!local/**/
!local/**/README.md
!local/README.md
