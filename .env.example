# Скопируйте этот файл в .env и заполните своими значениями.
# .env добавлен в .gitignore и не попадает в репозиторий.

# Адрес вашего инстанса Test IT (без слэша на конце)
TESTIT_URL=https://testit.example.com

# Приватный токен API (Test IT → Профиль → API-токены)
TESTIT_TOKEN=replace_me

# ID проекта в Test IT (виден в URL проекта)
TESTIT_PROJECT_ID=00000000-0000-0000-0000-000000000000
